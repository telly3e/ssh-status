#!/usr/bin/env bash

# ssh-status: a read-only status panel for interactive SSH logins.
# Bash 4+ is required. All collectors are deliberately local and read-only.

set -uo pipefail

VERSION="1.0.0"

WATCH=0
WATCH_INTERVAL=2
CLI_THEME=""
CONFIG_FILE="${SSH_STATUS_CONFIG:-/etc/ssh-status.conf}"
CONFIG_THEME=""
CONFIG_DOCKER="1"
CONFIG_DISK_EXCLUDE=""
CONFIG_ASCII="auto"

PROC_ROOT="${SSH_STATUS_PROC_ROOT:-/proc}"
OS_RELEASE="${SSH_STATUS_OS_RELEASE:-/etc/os-release}"
REBOOT_FILE="${SSH_STATUS_REBOOT_FILE:-/var/run/reboot-required}"

usage() {
    cat <<'EOF'
Usage: ssh-status [OPTIONS]

Render a read-only local system status panel.

Options:
  --watch [SECONDS]  refresh continuously (default: 2 seconds)
  --theme NAME       ocean, forest, or mono
  --config FILE      read configuration from FILE
  --help              show this help
  --version           show the version
EOF
}

die() {
    printf 'ssh-status: %s\n' "$*" >&2
    exit 2
}

trim() {
    local value="$1"
    value="${value#"${value%%[![:space:]]*}"}"
    value="${value%"${value##*[![:space:]]}"}"
    printf '%s' "$value"
}

unquote() {
    local value
    value="$(trim "$1")"
    if [[ "$value" == \"*\" && "$value" == *\" ]]; then
        value="${value:1:${#value}-2}"
    elif [[ "$value" == \'*\' && "$value" == *\' ]]; then
        value="${value:1:${#value}-2}"
    fi
    printf '%s' "$value"
}

load_config() {
    local line key value
    [[ -r "$CONFIG_FILE" ]] || return 0

    while IFS= read -r line || [[ -n "$line" ]]; do
        line="$(trim "$line")"
        [[ -z "$line" || "$line" == \#* || "$line" != *=* ]] && continue
        key="$(trim "${line%%=*}")"
        value="$(unquote "${line#*=}")"
        case "$key" in
            theme) CONFIG_THEME="$value" ;;
            docker) CONFIG_DOCKER="$value" ;;
            disk_exclude) CONFIG_DISK_EXCLUDE="$value" ;;
            ascii) CONFIG_ASCII="$value" ;;
        esac
    done < "$CONFIG_FILE"
}

parse_args() {
    while (($#)); do
        case "$1" in
            --watch)
                WATCH=1
                if (($# > 1)) && [[ "$2" != --* ]]; then
                    WATCH_INTERVAL="$2"
                    shift
                fi
                ;;
            --theme)
                (($# > 1)) || die '--theme requires a value'
                CLI_THEME="$2"
                shift
                ;;
            --theme=*) CLI_THEME="${1#*=}" ;;
            --config)
                (($# > 1)) || die '--config requires a file'
                CONFIG_FILE="$2"
                shift
                ;;
            --config=*) CONFIG_FILE="${1#*=}" ;;
            --help|-h) usage; exit 0 ;;
            --version|-V) printf 'ssh-status %s\n' "$VERSION"; exit 0 ;;
            *) die "unknown option: $1" ;;
        esac
        shift
    done

    [[ "$WATCH_INTERVAL" =~ ^[0-9]+([.][0-9]+)?$ ]] || die 'watch interval must be a positive number'
    awk -v n="$WATCH_INTERVAL" 'BEGIN { exit !(n > 0) }' || die 'watch interval must be greater than zero'
}

read_os_value() {
    local wanted="$1" line key value
    [[ -r "$OS_RELEASE" ]] || return 1
    while IFS= read -r line || [[ -n "$line" ]]; do
        [[ "$line" == *=* ]] || continue
        key="${line%%=*}"
        [[ "$key" == "$wanted" ]] || continue
        value="$(unquote "${line#*=}")"
        printf '%s' "$value"
        return 0
    done < "$OS_RELEASE"
    return 1
}

setup_style() {
    THEME="${CLI_THEME:-${SSH_STATUS_THEME:-${CONFIG_THEME:-ocean}}}"
    case "$THEME" in ocean|forest|mono) ;; *) die "unknown theme: $THEME" ;; esac

    DOCKER_ENABLED="${SSH_STATUS_DOCKER:-$CONFIG_DOCKER}"
    DISK_EXCLUDE="${SSH_STATUS_DISK_EXCLUDE:-$CONFIG_DISK_EXCLUDE}"
    ASCII_MODE="${SSH_STATUS_ASCII:-$CONFIG_ASCII}"

    if [[ -n "${NO_COLOR+x}" || ! -t 1 || "${TERM:-}" == dumb ]]; then
        THEME=mono
    fi

    RESET='' TITLE='' OK='' WARN='' BAD='' DIM=''
    if [[ "$THEME" != mono ]]; then
        RESET=$'\033[0m'
        DIM=$'\033[2m'
        OK=$'\033[32m'
        WARN=$'\033[33m'
        BAD=$'\033[31m'
        if [[ "$THEME" == forest ]]; then TITLE=$'\033[1;32m'; else TITLE=$'\033[1;36m'; fi
    fi

    local charmap=""
    if command -v locale >/dev/null 2>&1; then charmap="$(locale charmap 2>/dev/null || true)"; fi
    if [[ "$ASCII_MODE" == 1 || "$ASCII_MODE" == true || "$ASCII_MODE" == yes ||
          ( "$ASCII_MODE" == auto && "$charmap" != *UTF-8* && "$charmap" != *utf8* ) ]]; then
        ASCII=1
        TL='+' TR='+' BL='+' BR='+' H='-' V='|' LM='+' RM='+' BAR_ON='#' BAR_OFF='-' ELLIPSIS='...'
    else
        ASCII=0
        TL='╭' TR='╮' BL='╰' BR='╯' H='─' V='│' LM='├' RM='┤' BAR_ON='█' BAR_OFF='░' ELLIPSIS='…'
    fi

    if [[ -n "${SSH_STATUS_COLUMNS:-}" && "${SSH_STATUS_COLUMNS}" =~ ^[0-9]+$ ]]; then
        WIDTH="$SSH_STATUS_COLUMNS"
    elif [[ -t 1 ]] && command -v tput >/dev/null 2>&1; then
        WIDTH="$(tput cols 2>/dev/null || printf 80)"
    else
        WIDTH=80
    fi
    ((WIDTH < 50)) && WIDTH=50
    ((WIDTH > 120)) && WIDTH=120
}

repeat_char() {
    local char="$1" count="$2" out=""
    while ((count-- > 0)); do out+="$char"; done
    printf '%s' "$out"
}

display_width() {
    local text="$1" width=0 i char cp
    for ((i = 0; i < ${#text}; i++)); do
        char="${text:i:1}"
        printf -v cp '%d' "'$char"
        # Combining marks occupy no cell. East Asian wide/full-width code
        # points and emoji occupy two cells in the terminals we target.
        if (( (cp >= 0x0300 && cp <= 0x036f) ||
              (cp >= 0x1ab0 && cp <= 0x1aff) ||
              (cp >= 0x1dc0 && cp <= 0x1dff) ||
              (cp >= 0xfe20 && cp <= 0xfe2f) )); then
            :
        elif (( (cp >= 0x1100 && cp <= 0x115f) || cp == 0x2329 || cp == 0x232a ||
                 (cp >= 0x2e80 && cp <= 0xa4cf) ||
                 (cp >= 0xac00 && cp <= 0xd7a3) ||
                 (cp >= 0xf900 && cp <= 0xfaff) ||
                 (cp >= 0xfe10 && cp <= 0xfe19) ||
                 (cp >= 0xfe30 && cp <= 0xfe6f) ||
                 (cp >= 0xff00 && cp <= 0xff60) ||
                 (cp >= 0xffe0 && cp <= 0xffe6) ||
                 (cp >= 0x1f300 && cp <= 0x1faff) ||
                 (cp >= 0x20000 && cp <= 0x3fffd) )); then
            width=$((width + 2))
        else
            width=$((width + 1))
        fi
    done
    printf '%s' "$width"
}

clip() {
    local text="$1" max="$2" width ellipsis_width target=0 out='' i char char_width
    width="$(display_width "$text")"
    if ((width <= max)); then
        printf '%s' "$text"
        return
    fi

    ellipsis_width="$(display_width "$ELLIPSIS")"
    ((max > ellipsis_width)) || return
    max=$((max - ellipsis_width))
    width=0
    for ((i = 0; i < ${#text}; i++)); do
        char="${text:i:1}"
        char_width="$(display_width "$char")"
        ((width + char_width <= max)) || break
        out+="$char"
        width=$((width + char_width))
    done
    if [[ -n "$out" ]]; then
        printf '%s%s' "$out" "$ELLIPSIS"
    fi
}

border() {
    local left="$1" right="$2"
    printf '%s%s%s\n' "$left" "$(repeat_char "$H" "$((WIDTH - 2))")" "$right"
}

separator() { border "$LM" "$RM"; }

panel_line() {
    local text color_name color pad text_width
    text="$(clip "$1" "$((WIDTH - 4))")"
    color_name="${2:-plain}"
    case "$color_name" in
        title) color="$TITLE" ;;
        ok) color="$OK" ;;
        warn) color="$WARN" ;;
        bad) color="$BAD" ;;
        dim) color="$DIM" ;;
        *) color='' ;;
    esac
    text_width="$(display_width "$text")"
    pad=$((WIDTH - 4 - text_width))
    ((pad < 0)) && pad=0
    printf '%s %s%s%s%*s %s\n' "$V" "$color" "$text" "$RESET" "$pad" '' "$V"
}

header() {
    local label="$1" max fill label_width
    label=" $label "
    max=$((WIDTH - 2))
    label="$(clip "$label" "$max")"
    label_width="$(display_width "$label")"
    fill=$((max - label_width))
    printf '%s%s%s%s%s%s\n' "$TL" "$TITLE" "$label" "$(repeat_char "$H" "$fill")" "$RESET" "$TR"
}

format_bytes() {
    awk -v n="${1:-0}" 'BEGIN {
        split("B KiB MiB GiB TiB PiB", u, " "); i=1;
        while (n >= 1024 && i < 6) { n/=1024; i++ }
        if (i == 1) printf "%.0f %s", n, u[i]; else printf "%.1f %s", n, u[i]
    }'
}

format_uptime() {
    local seconds="${1%%.*}" days hours minutes out=""
    [[ "$seconds" =~ ^[0-9]+$ ]] || seconds=0
    days=$((seconds / 86400)); hours=$(((seconds % 86400) / 3600)); minutes=$(((seconds % 3600) / 60))
    ((days > 0)) && out+="${days}d "
    printf '%s%02dh %02dm' "$out" "$hours" "$minutes"
}

level_for_percent() {
    local percent="${1:-0}"
    if ((percent >= 90)); then printf bad; elif ((percent >= 80)); then printf warn; else printf ok; fi
}

progress_bar() {
    local percent="${1:-0}" length="${2:-20}" filled empty
    ((percent < 0)) && percent=0
    ((percent > 100)) && percent=100
    filled=$(((percent * length + 50) / 100)); empty=$((length - filled))
    printf '[%s%s]' "$(repeat_char "$BAR_ON" "$filled")" "$(repeat_char "$BAR_OFF" "$empty")"
}

primary_ipv4() {
    local route ip
    command -v ip >/dev/null 2>&1 || { printf 'N/A'; return; }
    route="$(ip -4 route get 1.1.1.1 2>/dev/null | head -n 1 || true)"
    ip="$(awk '{ for (i=1; i<=NF; i++) if ($i == "src" && i < NF) { print $(i+1); exit } }' <<< "$route")"
    [[ -n "$ip" ]] && printf '%s' "$ip" || printf 'N/A'
}

cpu_model() {
    local cpu=''
    if [[ -r "$PROC_ROOT/cpuinfo" ]]; then
        cpu="$(awk -F: '/^(model name|Hardware)[[:space:]]*:/ { sub(/^[[:space:]]+/, "", $2); print $2; exit }' "$PROC_ROOT/cpuinfo")"
    fi
    [[ -n "$cpu" ]] && printf '%s' "$cpu" || printf 'N/A'
}

cpu_counts() {
    local physical cores threads
    threads="$(awk '/^processor[[:space:]]*:/ { n++ } END { print n+0 }' "$PROC_ROOT/cpuinfo" 2>/dev/null || printf 0)"
    cores="$(awk -F: '
        /^physical id[[:space:]]*:/ { gsub(/[[:space:]]/, "", $2); p=$2 }
        /^core id[[:space:]]*:/ { gsub(/[[:space:]]/, "", $2); if (p != "") seen[p ":" $2]=1 }
        END { for (x in seen) n++; print n+0 }
    ' "$PROC_ROOT/cpuinfo" 2>/dev/null || printf 0)"
    ((cores == 0)) && cores="$threads"
    printf '%sC/%sT' "$cores" "$threads"
}

memory_stats() {
    local output
    output="$(free -b 2>/dev/null || true)"
    awk '
        /^Mem:/ { mt=$2; mu=$3 }
        /^Swap:/ { st=$2; su=$3 }
        END { printf "%.0f %.0f %.0f %.0f", mt+0, mu+0, st+0, su+0 }
    ' <<< "$output"
}

is_excluded_mount() {
    local mount="$1" pattern normalized
    normalized="${DISK_EXCLUDE//,/ }"
    for pattern in $normalized; do
        [[ "$mount" == $pattern ]] && return 0
    done
    return 1
}

render_disks() {
    local line filesystem total used avail percent mount pct level bar bar_len
    local found=0
    while IFS= read -r line; do
        [[ -z "$line" ]] && continue
        read -r filesystem total used avail percent mount <<< "$line"
        [[ -n "${mount:-}" && "$total" =~ ^[0-9]+$ ]] || continue
        is_excluded_mount "$mount" && continue
        pct="${percent%%%}"
        [[ "$pct" =~ ^[0-9]+$ ]] || pct=0
        bar_len=20
        ((WIDTH < 72)) && bar_len=10
        bar="$(progress_bar "$pct" "$bar_len")"
        level="$(level_for_percent "$pct")"
        panel_line "磁盘 ${mount}  $(format_bytes "$used") / $(format_bytes "$total") (${pct}%)  ${bar}" "$level"
        found=1
    done < <(df -P -B1 -x tmpfs -x devtmpfs 2>/dev/null | awk 'NR > 1 { print }' || true)
    ((found == 1)) || panel_line '磁盘 N/A' dim
}

render_docker() {
    local output rc=0 total=0 running=0 stopped=0
    local names_unhealthy=() names_dead=() names_restart=() names_exited=()
    local name state status lower

    [[ "$DOCKER_ENABLED" == 1 || "$DOCKER_ENABLED" == true || "$DOCKER_ENABLED" == yes ]] || return 0
    command -v docker >/dev/null 2>&1 || return 0

    output="$(docker ps -a --format '{{.Names}}|{{.State}}|{{.Status}}' 2>/dev/null)" || rc=$?
    separator
    if ((rc != 0)); then
        panel_line 'Docker     未授权读取 Docker 状态' warn
        return 0
    fi

    while IFS='|' read -r name state status; do
        [[ -n "$name" ]] || continue
        total=$((total + 1))
        lower="${state,,} ${status,,}"
        if [[ "$state" == running ]]; then running=$((running + 1)); else stopped=$((stopped + 1)); fi
        [[ "$lower" == *unhealthy* ]] && names_unhealthy+=("$name")
        [[ "$lower" == *dead* ]] && names_dead+=("$name")
        [[ "$lower" == *restarting* ]] && names_restart+=("$name")
        [[ "$lower" == *exited* ]] && names_exited+=("$name")
    done <<< "$output"

    panel_line "Docker     ${total} containers: ${running} running, ${stopped} stopped" "$([[ ${#names_unhealthy[@]} -eq 0 && ${#names_dead[@]} -eq 0 && ${#names_restart[@]} -eq 0 && ${#names_exited[@]} -eq 0 ]] && printf ok || printf warn)"
    ((${#names_unhealthy[@]})) && panel_line "           ! unhealthy: ${names_unhealthy[*]}" bad
    ((${#names_dead[@]})) && panel_line "           ! dead: ${names_dead[*]}" bad
    ((${#names_restart[@]})) && panel_line "           ! restarting: ${names_restart[*]}" bad
    ((${#names_exited[@]})) && panel_line "           ! exited: ${names_exited[*]}" warn
}

render_health() {
    local failed='' rc=0 services='' distro id_like reboot='N/A' reboot_level=dim
    separator

    if command -v systemctl >/dev/null 2>&1; then
        failed="$(systemctl --failed --no-legend --plain 2>/dev/null)" || rc=$?
        if ((rc == 0)); then
            services="$(awk 'NF { if (out != "") out=out ", "; out=out $1 } END { print out }' <<< "$failed")"
            if [[ -n "$services" ]]; then
                panel_line "系统健康  ! systemd: ${services}" bad
            else
                panel_line '系统健康  systemd: OK' ok
            fi
        else
            panel_line '系统健康  systemd: N/A' dim
        fi
    else
        panel_line '系统健康  systemd: N/A' dim
    fi

    distro="$(read_os_value ID 2>/dev/null || true)"
    id_like="$(read_os_value ID_LIKE 2>/dev/null || true)"
    if [[ "$distro $id_like" == *debian* || "$distro $id_like" == *ubuntu* ]]; then
        if [[ -e "$REBOOT_FILE" ]]; then reboot='需要重启'; reboot_level=bad; else reboot='no'; reboot_level=ok; fi
    fi
    panel_line "           Reboot: ${reboot}" "$reboot_level"
}

render() {
    local host os_name os_version now uptime load1 load5 load15
    local mem_total mem_used swap_total swap_used mem_pct=0 swap_pct=0 processes users

    host="$(hostname -f 2>/dev/null || hostname 2>/dev/null || printf unknown)"
    os_name="$(read_os_value NAME 2>/dev/null || printf Linux)"
    os_version="$(read_os_value VERSION_ID 2>/dev/null || true)"
    now="$(date '+%Y-%m-%d %H:%M')"
    uptime="$(awk '{ print $1 }' "$PROC_ROOT/uptime" 2>/dev/null || printf 0)"
    read -r load1 load5 load15 _ < "$PROC_ROOT/loadavg" 2>/dev/null || { load1=N/A; load5=N/A; load15=N/A; }
    read -r mem_total mem_used swap_total swap_used <<< "$(memory_stats)"
    ((mem_total > 0)) && mem_pct=$((mem_used * 100 / mem_total))
    ((swap_total > 0)) && swap_pct=$((swap_used * 100 / swap_total))
    processes="$(ps -e --no-headers 2>/dev/null | awk 'END { print NR+0 }')"
    users="$(who 2>/dev/null | awk 'END { print NR+0 }')"

    header "${host} ─ ${os_name}${os_version:+ $os_version} ─ ${now}"
    panel_line "核心信息  CPU: $(cpu_model) ($(cpu_counts))" title
    panel_line "           IP: $(primary_ipv4)    Uptime: $(format_uptime "$uptime")"
    separator
    panel_line "资源使用  Load: ${load1} / ${load5} / ${load15}    Processes: ${processes}    Users: ${users}"
    panel_line "           Memory: $(format_bytes "$mem_used") / $(format_bytes "$mem_total") (${mem_pct}%)" "$(level_for_percent "$mem_pct")"
    panel_line "           Swap: $(format_bytes "$swap_used") / $(format_bytes "$swap_total") (${swap_pct}%)" "$(level_for_percent "$swap_pct")"
    separator
    render_disks
    render_docker
    render_health
    border "$BL" "$BR"
}

main() {
    parse_args "$@"
    load_config
    setup_style
    if ((WATCH == 0)); then
        render
        return 0
    fi

    trap 'printf "\033[0m\n"; exit 0' INT TERM
    while :; do
        printf '\033[H\033[2J'
        render
        sleep "$WATCH_INTERVAL"
    done
}

main "$@"
